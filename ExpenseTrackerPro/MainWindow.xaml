<Window x:Class="ExpenseTrackerPro.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Title="ExpenseTracker Pro"
         Height="700"
         Width="1200"
         WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Sidebar + Main Content -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#1E293B">

            <StackPanel Margin="15">

                <TextBlock Text="ExpenseTracker"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0 20 0 40"/>

                <Button x:Name="btnDelete"
                        Content="Delete Selected"
                        Height="45"
                        Margin="0 0 0 15"
                        Background="#DC2626"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="btnDelete_Click"/>

                <Button x:Name="btnAbout"
                        Content="About"
                        Height="45"
                        Margin="0 5"
                        Click="btnAbout_Click"/>

                <Button x:Name="btnExport"
                        Content="Export CSV"
                        Height="45"
                        Margin="0 0 0 15"
                        Background="#059669"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="btnExport_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1"
              Background="#F1F5F9">

            <Grid.RowDefinitions>
                <RowDefinition Height="170"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">

                <StackPanel Margin="25">

                    <TextBlock Text="Dashboard"
                               FontSize="30"
                               FontWeight="Bold"/>

                    <WrapPanel Margin="0,15,0,0">

                        <Border Background="White"
                                Width="180"
                                Height="80"
                                CornerRadius="10"
                                Margin="0,0,15,0">

                            <StackPanel Margin="10">
                                <TextBlock Text="Total Expense"/>
                                <TextBlock x:Name="txtTotalExpense"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                        <Border Background="White"
                                Width="180"
                                Height="80"
                                CornerRadius="10"
                                Margin="0,0,15,0">

                            <StackPanel Margin="10">
                                <TextBlock Text="Total Entries"/>
                                <TextBlock x:Name="txtTotalEntries"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                        <Border Background="White"
                                Width="180"
                                Height="80"
                                CornerRadius="10">

                            <StackPanel Margin="10">
                                <TextBlock Text="Highest Expense"/>
                                <TextBlock x:Name="txtHighestExpense"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                    </WrapPanel>

                </StackPanel>

            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL : ADD EXPENSE -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="10"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Add Expense"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0 0 0 20"/>

                        <TextBlock Text="Category"/>

                        <ComboBox x:Name="cmbCategory"
                                  Height="40"
                                  Margin="0 5 0 15"
                                  SelectedIndex="0">

                            <ComboBoxItem Content="Food"/>
                            <ComboBoxItem Content="Travel"/>
                            <ComboBoxItem Content="Shopping"/>
                            <ComboBoxItem Content="Bills"/>
                            <ComboBoxItem Content="Healthcare"/>
                            <ComboBoxItem Content="Entertainment"/>

                        </ComboBox>

                        <TextBlock Text="Amount"/>

                        <TextBox x:Name="txtAmount"
                                 Height="40"
                                 Margin="0 5 0 15"
                                 ToolTip="Enter amount in INR"/>

                        <TextBlock Text="Description"/>

                        <TextBox x:Name="txtDescription"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Margin="0 5 0 20"/>

                        <Button x:Name="btnSave"
                                Margin="0 10 0 0"
                                Content="Save Expense"
                                Height="50"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="btnSave_Click"/>
                    </StackPanel>

                </Border>

                <!-- RIGHT PANEL : SEARCH + TABLE -->
                <Border Grid.Column="1"
                        Margin="20 0 0 0"
                        Background="White"
                        CornerRadius="10"
                        Padding="15">

                <!-- Search + Table -->
                    <StackPanel Grid.Row="0">

                        <TextBox x:Name="txtSearch"
                                     Height="40"
                                     Margin="0 0 0 15"
                                     ToolTip="Search by Category..."
                                     TextChanged="txtSearch_TextChanged"/>

                        <DataGrid x:Name="expenseGrid"
                                  SelectionChanged="expenseGrid_SelectionChanged"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="Horizontal">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Category"
                                                    Binding="{Binding Category}"
                                                    Width="1.2*"/>

                                <DataGridTextColumn Header="Amount (₹)"
                                                    Binding="{Binding Amount, StringFormat=₹{0:N2}}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Description"
                                                    Binding="{Binding Description}"
                                                    Width="2*"/>

                                <DataGridTextColumn Header="Date"
                                                    Binding="{Binding Date}"
                                                    Width="1.8*"/>

                            </DataGrid.Columns>

                        </DataGrid> 

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
